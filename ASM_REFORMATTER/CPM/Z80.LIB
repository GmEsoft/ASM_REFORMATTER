;	Z80.LIB
;	=======
;
;	Macros collection for 8080 assemblers
;	to support extended Z-80 instructions
;
;	Original (C) DRI
;
;	Version APR.2026
;	- Fixed JR displacements
;	- Added corresponding Z-80 instructions as comments

;	@CHK MACRO USED FOR CHECKING 8 BIT DISPLACMENTS
;
@CHK	MACRO	?DD	;; USED FOR CHECKING RANGE OF 8-BIT DISP.S
	IF (?DD GT 7FH) AND (?DD LT 0FF80H)
 'DISPLACEMENT RANGE ERROR - Z80 LIB'
	ENDIF
	ENDM

LDX	MACRO	?R,?D		;LD	?R,(IX+?D)
	@CHK	?D
	DB	0DDH,?R*8+46H,?D
	ENDM
LDY	MACRO	?R,?D		;LD	?R,(IY+?D)
	@CHK	?D
	DB	0FDH,?R*8+46H,?D
	ENDM
STX	MACRO	?R,?D		;LD	(IX+?D),?R
	@CHK	?D
	DB	0DDH,70H+?R,?D
	ENDM
STY	MACRO	?R,?D		;LD	(IY+?D),?R
	@CHK	?D
	DB	0FDH,70H+?R,?D
	ENDM
MVIX	MACRO	?N,?D		;LD	(IX+?D),?N
	@CHK	?D
	DB	0DDH,36H,?D,?N
	ENDM
MVIY	MACRO	?N,?D		;LD	(IY+?D),?N
	@CHK	?D
	DB	0FDH,36H,?D,?N
	ENDM
LDAI	MACRO			;LD	A,I
	DB	0EDH,57H
	ENDM
LDAR	MACRO			;LD	A,R
	DB	0EDH,5FH
	ENDM
STAI	MACRO			;LD	I,A
	DB	0EDH,47H
	ENDM
STAR	MACRO			;LD	R,A
	DB	0EDH,4FH
	ENDM

LXIX	MACRO	?NNNN		;LD	IX,?NNNN
	DB	0DDH,21H
	DW	?NNNN
	ENDM
LXIY	MACRO	?NNNN		;LD	IY,?NNNN
	DB	0FDH,21H
	DW	?NNNN
	ENDM
LDED	MACRO	?NNNN		;LD	DE,(?NNNN)
	DB	0EDH,5BH
	DW	?NNNN
	ENDM
LBCD	MACRO	?NNNN		;LD	BC,(?NNNN)
	DB	0EDH,4BH
	DW	?NNNN
	ENDM
LSPD	MACRO	?NNNN		;LD	SP,(?NNNN)
	DB	0EDH,07BH
	DW	?NNNN
	ENDM
LIXD	MACRO	?NNNN		;LD	IX,(?NNNN)
	DB	0DDH,2AH
	DW	?NNNN
	ENDM
LIYD	MACRO	?NNNN		;LD	IY,(?NNNN)
	DB	0FDH,2AH
	DW	?NNNN
	ENDM
SBCD	MACRO	?NNNN		;LD	(?NNNN),BC
	DB	0EDH,43H
	DW	?NNNN
	ENDM
SDED	MACRO	?NNNN		;LD	(?NNNN),DE
	DB	0EDH,53H
	DW	?NNNN
	ENDM
SSPD	MACRO	?NNNN		;LD	(?NNNN),SP
	DB	0EDH,73H
	DW	?NNNN
	ENDM
SIXD	MACRO	?NNNN		;LD	(?NNNN),IX
	DB	0DDH,22H
	DW	?NNNN
	ENDM
SIYD	MACRO	?NNNN		;LD	(?NNNN),IY
	DB	0FDH,22H
	DW	?NNNN
	ENDM
SPIX	MACRO			;LD	SP,IX
	DB	0DDH,0F9H
	ENDM
SPIY	MACRO			;LD	SP,IY
	DB	0FDH,0F9H
	ENDM
PUSHIX	MACRO			;PUSH	IX
	DB	0DDH,0E5H
	ENDM
PUSHIY	MACRO			;PUSH	IY
	DB	0FDH,0E5H
	ENDM
POPIX	MACRO			;POP	IX
	DB	0DDH,0E1H
	ENDM
POPIY	MACRO			;POP	IY
	DB	0FDH,0E1H
	ENDM
EXAF	MACRO			;EX	AF,AF'
	DB	08H
	ENDM
EXX	MACRO			;EXX
	DB	0D9H
	ENDM
XTIX	MACRO			;EX	(SP),IX
	DB	0DDH,0E3H
	ENDM
XTIY	MACRO			;EX	(SP),IY
	DB	0FDH,0E3H
	ENDM

LDI	MACRO			;LDI
	DB	0EDH,0A0H
	ENDM
LDIR	MACRO			;LDIR
	DB	0EDH,0B0H
	ENDM
LDD	MACRO			;LDD
	DB	0EDH,0A8H
	ENDM
LDDR	MACRO			;LDDR
	DB	0EDH,0B8H
	ENDM
CCI	MACRO			;CPI
	DB	0EDH,0A1H
	ENDM
CCIR	MACRO			;CPIR
	DB	0EDH,0B1H
	ENDM
CCD	MACRO
	DB	0EDH,0A9H	;CPD
	ENDM
CCDR	MACRO			;CPDR
	DB	0EDH,0B9H
	ENDM

ADDX	MACRO	?D		;ADD	A,(IX+?D)
	@CHK	?D
	DB	0DDH,86H,?D
	ENDM
ADDY	MACRO	?D		;ADD	A,(IY+?D)
	@CHK	?D
	DB	0FDH,86H,?D
	ENDM
ADCX	MACRO	?D		;ADC	A,(IX+?D)
	@CHK	?D
	DB	0DDH,8EH,?D
	ENDM
ADCY	MACRO	?D		;ADC	A,(IY+?D)
	@CHK	?D
	DB	0FDH,8EH,?D
	ENDM
SUBX	MACRO	?D		;SUB	(IX+?D)
	@CHK	?D
	DB	0DDH,96H,?D
	ENDM
SUBY	MACRO	?D		;SUB	(IY+?D)
	@CHK	?D
	DB	0FDH,96H,?D
	ENDM
SBCX	MACRO	?D		;SBC	A,(IX+?D)
	@CHK	?D
	DB	0DDH,9EH,?D
	ENDM
SBCY	MACRO	?D		;SBC	A,(IY+?D)
	@CHK	?D
	DB	0FDH,9EH,?D
	ENDM
ANDX	MACRO	?D		;AND	(IX+?D)
	@CHK	?D
	DB	0DDH,0A6H,?D
	ENDM
ANDY	MACRO	?D		;AND	(IY+?D)
	@CHK	?D
	DB	0FDH,0A6H,?D
	ENDM
XORX	MACRO	?D		;XOR	(IX+?D)
	@CHK	?D
	DB	0DDH,0AEH,?D
	ENDM
XORY	MACRO	?D		;XOR	(IY+?D)
	@CHK	?D
	DB	0FDH,0AEH,?D
	ENDM
ORX	MACRO	?D		;OR	(IX+?D)
	@CHK	?D
	DB	0DDH,0B6H,?D
	ENDM
ORY	MACRO	?D		;OR	(IY+?D)
	@CHK	?D
	DB	0FDH,0B6H,?D
	ENDM
CMPX	MACRO	?D		;CP	(IX+?D)
	@CHK	?D
	DB	0DDH,0BEH,?D
	ENDM
CMPY	MACRO	?D		;CP	(IY+?D)
	@CHK	?D
	DB	0FDH,0BEH,?D
	ENDM
INRX	MACRO	?D		;INC	(IX+?D)
	@CHK	?D
	DB	0DDH,34H,?D
	ENDM
INRY	MACRO	?D		;INC	(IY+?D)
	@CHK	?D
	DB	0FDH,34H,?D
	ENDM
DCRX	MACRO	?D		;DEC	(IX+?D)
	@CHK	?D
	DB	0DDH,035H,?D
	ENDM
DCRY	MACRO	?D		;DEC	(IY+?D)
	@CHK	?D
	DB	0FDH,35H,?D
	ENDM

NEG	MACRO			;NEG
	DB	0EDH,44H
	ENDM
IM0	MACRO			;IM	0
	DB	0EDH,46H
	ENDM
IM1	MACRO			;IM	1
	DB	0EDH,56H
	ENDM
IM2	MACRO			;IM	2
	DB	0EDH,5EH
	ENDM


BC	EQU	0
DE	EQU	2
HL	EQU	4
IX	EQU	4
IY	EQU	4
DADC	MACRO	?R		;ADC	HL,?R
	DB	0EDH,?R*8+4AH
	ENDM
DSBC	MACRO	?R		;SBC	HL,?R
	DB	0EDH,?R*8+42H
	ENDM
DADX	MACRO	?R		;ADD	IX,?R
	DB	0DDH,?R*8+09H
	ENDM
DADY	MACRO	?R		;ADD	IY,?R
	DB	0FDH,?R*8+09H
	ENDM
INXIX	MACRO			;INC	IX
	DB	0DDH,23H
	ENDM
INXIY	MACRO			;INC	IY
	DB	0FDH,23H
	ENDM
DCXIX	MACRO			;DEC	IX
	DB	0DDH,2BH
	ENDM
DCXIY	MACRO			;DEC	IY
	DB	0FDH,2BH
	ENDM

BIT	MACRO	?N,?R		;BIT	?N,?R
	DB	0CBH,?N*8+?R+40H
	ENDM
SETB	MACRO	?N,?R		;SET	?N,?R
	DB	0CBH,?N*8+?R+0C0H
	ENDM
RES	MACRO	?N,?R		;RES	?N,?R
	DB	0CBH,?N*8+?R+80H
	ENDM

BITX	MACRO	?N,?D		;BIT	?N,(IX+?D)
	@CHK	?D
	DB	0DDH,0CBH,?D,?N*8+46H
	ENDM
BITY	MACRO	?N,?D		;BIT	?N,(IY+?D)
	@CHK	?D
	DB	0FDH,0CBH,?D,?N*8+46H
	ENDM
SETX	MACRO	?N,?D		;SET	?N,(IX+?D)
	@CHK	?D
	DB	0DDH,0CBH,?D,?N*8+0C6H
	ENDM
SETY	MACRO	?N,?D		;SET	?N,(IY+?D)
	@CHK	?D
	DB	0FDH,0CBH,?D,?N*8+0C6H
	ENDM
RESX	MACRO	?N,?D		;RES	?N,(IX+?D)
	@CHK	?D
	DB	0DDH,0CBH,?D,?N*8+86H
	ENDM
RESY	MACRO	?N,?D		;RES	?N,(IY+?D)
	@CHK	?D
	DB	0FDH,0CBH,?D,?N*8+86H
	ENDM

;	FIX APR.2026:
;	DISPLACEMENT FROM ??-$-1 TO ??-$-2
JR	MACRO	?N		;JR	?N
	DB	18H,?N-$-2
	ENDM
JRC	MACRO	?N		;JR	C,?N
	DB	38H,?N-$-2
	ENDM
JRNC	MACRO	?N		;JR	NC,?N
	DB	30H,?N-$-2
	ENDM
JRZ	MACRO	?N		;JR	Z,?N
	DB	28H,?N-$-2
	ENDM
JRNZ	MACRO	?N		;JR	NZ,?N
	DB	20H,?N-$-2
	ENDM
DJNZ	MACRO	?N		;DJNZ	?N
	DB	10H,?N-$-2
	ENDM

PCIX	MACRO			;JP	(IX)
	DB	0DDH,0E9H
	ENDM
PCIY	MACRO			;JP	(IY)
	DB	0FDH,0E9H
	ENDM

RETI	MACRO			;RETI
	DB	0EDH,4DH
	ENDM
RETN	MACRO			;RETN
	DB	0EDH,45H
	ENDM

INP	MACRO	?R		;IN	?R,(C)
	DB	0EDH,?R*8+40H
	ENDM
OUTP	MACRO	?R		;OUT	(C),?R
	DB	0EDH,?R*8+41H
	ENDM
INI	MACRO			;INI
	DB	0EDH,0A2H
	ENDM
INIR	MACRO			;INIR
	DB	0EDH,0B2H
	ENDM
IND	MACRO			;IND
	DB	0EDH,0AAH
	ENDM
INDR	MACRO			;INDR
	DB	0EDH,0BAH
	ENDM
OUTI	MACRO			;OUTI
	DB	0EDH,0A3H
	ENDM
OUTIR	MACRO			;OTIR
	DB	0EDH,0B3H
	ENDM
OUTD	MACRO			;OUTD
	DB	0EDH,0ABH
	ENDM
OUTDR	MACRO			;OTDR
	DB	0EDH,0BBH
	ENDM


RLCR	MACRO	?R		;RLC	?R
	DB	0CBH, 00H + ?R
	ENDM
RLCX	MACRO	?D		;RLC	(IX+?D)
	@CHK	?D
	DB	0DDH, 0CBH, ?D, 06H
	ENDM
RLCY	MACRO	?D		;RLC	(IY+?D)
	@CHK	?D
	DB	0FDH, 0CBH, ?D, 06H
	ENDM
RALR	MACRO	?R		;RL	?R
	DB	0CBH, 10H+?R
	ENDM
RALX	MACRO	?D		;RL	(IX+?D)
	@CHK	?D
	DB	0DDH, 0CBH, ?D, 16H
	ENDM
RALY	MACRO	?D		;RL	(IY+?D)
	@CHK	?D
	DB	0FDH, 0CBH, ?D, 16H
	ENDM
RRCR	MACRO	?R		;RRC	?R
	DB	0CBH, 08H + ?R
	ENDM
RRCX	MACRO	?D		;RRC	(IX+?D)
	@CHK	?D
	DB	0DDH, 0CBH, ?D, 0EH
	ENDM
RRCY	MACRO	?D		;RRC	(IY+?D)
	@CHK	?D
	DB	0FDH, 0CBH, ?D, 0EH
	ENDM
RARR	MACRO	?R		;RR	?R
	DB	0CBH, 18H + ?R
	ENDM
RARX	MACRO	?D		;RR	(IX+?D)
	@CHK	?D
	DB	0DDH, 0CBH, ?D, 1EH
	ENDM
RARY	MACRO	?D		;RR	(IY+?D)
	@CHK	?D
	DB	0FDH, 0CBH, ?D, 1EH
	ENDM
SLAR	MACRO	?R		;SLA	?R
	DB	0CBH, 20H + ?R
	ENDM
SLAX	MACRO	?D		;SLA	(IX+?D)
	@CHK	?D
	DB	0DDH, 0CBH, ?D, 26H
	ENDM
SLAY	MACRO	?D		;SLA	(IY+?D)
	@CHK	?D
	DB	0FDH, 0CBH, ?D, 26H
	ENDM
SRAR	MACRO	?R		;SRA	?R
	DB	0CBH, 28H+?R
	ENDM
SRAX	MACRO	?D		;SRA	(IX+?D)
	@CHK	?D
	DB	0DDH, 0CBH, ?D, 2EH
	ENDM
SRAY	MACRO	?D		;SRA	(IY+?D)
	@CHK	?D
	DB	0FDH, 0CBH, ?D, 2EH
	ENDM
SRLR	MACRO	?R		;SRL	?R
	DB	0CBH, 38H + ?R
	ENDM
SRLX	MACRO	?D		;SRL	(IX+?D)
	@CHK	?D
	DB	0DDH, 0CBH, ?D, 3EH
	ENDM
SRLY	MACRO	?D		;SRL	(IY+?D)
	@CHK	?D
	DB	0FDH, 0CBH, ?D, 3EH
	ENDM
RLD	MACRO			;RLD
	DB	0EDH, 6FH
	ENDM
RRD	MACRO			;RRD
	DB	0EDH, 67H
	ENDM
